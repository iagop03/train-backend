# Cloud SQL Database Configuration
DB_HOST=10.1.0.0
DB_PORT=5432
DB_NAME=train_db
DB_USER=train_app
DB_PASSWORD=your_secure_password_here

# SSL Configuration
DB_SSL_MODE=require
DB_SSL_CERT=/path/to/certs/client-cert.pem
DB_SSL_KEY=/path/to/certs/client-key.pem
DB_SSL_ROOT_CERT=/path/to/certs/server-ca.pem

# Cloud SQL Proxy (if using)
CLOUDSQL_INSTANCE=project_id:us-central1:train-postgres-prod
CLOUDSQL_PROXY_PORT=5432

# GCP Configuration
GCP_PROJECT_ID=your_project_id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Spring Boot
SPRING_PROFILES_ACTIVE=prod
JDBC_MAX_POOL_SIZE=20
JDBC_MIN_IDLE=5
