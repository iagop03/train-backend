# GCP Project Configuration
GCP_PROJECT_ID=train-ai-gym-tracker
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Service Accounts
CLOUD_RUN_SERVICE_ACCOUNT=train-cloud-run@train-ai-gym-tracker.iam.gserviceaccount.com
CLOUD_BUILD_SERVICE_ACCOUNT=train-cloud-build@train-ai-gym-tracker.iam.gserviceaccount.com
APP_SERVICE_ACCOUNT=train-app-service@train-ai-gym-tracker.iam.gserviceaccount.com

# Cloud SQL Configuration
CLOUD_SQL_INSTANCE=train-postgres-primary
CLOUD_SQL_DATABASE_VERSION=POSTGRES_15
CLOUD_SQL_TIER=db-f1-micro
CLOUD_SQL_STORAGE_GB=50
CLOUD_SQL_BACKUP_ENABLED=true
CLOUD_SQL_BACKUP_LOCATION=us
CLOUD_SQL_USER=postgres

# Application Database
DATABASE_HOST=/cloudsql/train-ai-gym-tracker:us-central1:train-postgres-primary
DATABASE_PORT=5432
DATABASE_NAME=train_db
DATABASE_USER=app_user

# Cloud Run Configuration
CLOUD_RUN_SERVICE_NAME=train-backend
CLOUD_RUN_MEMORY=2Gi
CLOUD_RUN_CPU=2
CLOUD_RUN_TIMEOUT=3600
CLOUD_RUN_CONCURRENCY=100
CLOUD_RUN_MIN_INSTANCES=1
CLOUD_RUN_MAX_INSTANCES=100

# Container Registry
CONTAINER_REGISTRY=gcr.io
CONTAINER_IMAGE_NAME=gcr.io/train-ai-gym-tracker/train-backend
CONTAINER_IMAGE_TAG=latest

# Secret Manager
SECRET_MANAGER_PROJECT_ID=train-ai-gym-tracker
JWT_SECRET_NAME=jwt-secret
API_KEY_SECRET_NAME=api-key
KEYCLOAK_PASSWORD_SECRET_NAME=keycloak-password
MONGODB_URI_SECRET_NAME=mongodb-uri

# Keycloak Configuration
KEYCLOAK_REALM=train
KEYCLOAK_AUTH_SERVER_URL=https://keycloak.example.com/auth
KEYCLOAK_CLIENT_ID=train-backend
KEYCLOAK_CLIENT_SECRET_NAME=keycloak-client-secret

# MongoDB Atlas
MONGODB_CLUSTER=train-cluster
MONGODB_DATABASE=train_analytics
MONGODB_CONNECTION_POOL_SIZE=50

# Logging and Monitoring
LOG_LEVEL=INFO
GCP_LOGGING_ENABLED=true
GCP_MONITORING_ENABLED=true
GCP_TRACE_ENABLED=true
GCP_PROFILER_ENABLED=true

# Cloud Build
CLOUD_BUILD_GITHUB_OWNER=iagop03
CLOUD_BUILD_GITHUB_REPO=train-backend
CLOUD_BUILD_GITHUB_BRANCH=main
CLOUD_BUILD_GITHUB_TOKEN_SECRET_NAME=github-token

# Billing and Cost Management
BILLING_ACCOUNT_ID=
BUDGET_THRESHOLD_USD=100
COST_ANOMALY_THRESHOLD=20

# DNS Configuration
DNS_ZONE_NAME=train-api
DOMAIN_NAME=api.traingymtracker.com

# Network Configuration
VPC_NETWORK_NAME=train-vpc
CLOUD_SQL_NETWORK_IP_RANGE=10.20.0.0/16

# Environment
APP_ENV=production
DEBUG=false
